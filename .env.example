# ═══════════════════════════════════════════════════════
#  AROGYOS — Environment Variables Template
#  Copy this to .env and fill in your real values
# ═══════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_SERVICE_ROLE_KEY

# ── Razorpay (India payments) ─────────────────────────
# Get from: razorpay.com → Settings → API Keys
# Use rzp_test_... for testing, rzp_live_... for real money
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Paddle (International payments) ──────────────────
# Get from: vendors.paddle.com → Developer Tools → Authentication
# Server-side:
PADDLE_VENDOR_ID=12345
PADDLE_AUTH_CODE=your_auth_code_here
PADDLE_SANDBOX=true
# Frontend (Vite only exposes VITE_ prefixed vars to the browser):
VITE_PADDLE_VENDOR_ID=12345
VITE_PADDLE_PRODUCT_ID_MONTHLY=12345
VITE_PADDLE_PRODUCT_ID_HALFYEAR=12346
VITE_PADDLE_PRODUCT_ID_ANNUAL=12347
VITE_PADDLE_SANDBOX=true

# ── OTP: Email via Resend ────────────────────────────
# Get from: resend.com → API Keys (free: 100 emails/day)
# Signup: resend.com → Create API Key → copy it here
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
# Use 'onboarding@resend.dev' for testing (no domain needed)
# Or your verified domain: 'AROGYOS <noreply@arogyos.in>'
RESEND_FROM_EMAIL=AROGYOS <noreply@arogyos.in>

# ── OTP: SMS via MSG91 (India, ~₹0.10/SMS) ───────────
# Get from: msg91.com → API → Auth Key
# Also create an OTP template in MSG91 dashboard
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY
MSG91_TEMPLATE_ID=YOUR_MSG91_TEMPLATE_ID

# ── OTP: SMS via Twilio (International) ──────────────
# Get from: twilio.com → Console → Account SID + Auth Token
# Only needed if serving international users via SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Push Notifications ────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VITE_ prefix exposes public key to browser (safe)
VITE_VAPID_PUBLIC_KEY=BGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:support@arogyos.in

# ── App ───────────────────────────────────────────────
PORT=3001
APP_URL=https://healthos-app-two.vercel.app
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
